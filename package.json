{
  "name": "blau",
  "private": true,
  "type": "module",
  "workspaces": ["workers/*"],
  "packageManager": "bun@1.3.14",
  "overrides": {
    "esbuild": "0.28.1"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check": "turbo run check",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "audit": "bun audit",
    "ci": "bun run lint && bun run check && bun run test && bun run build && bun run audit",
    "preview": "turbo run preview",
    "deploy": "turbo run deploy"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.7.0",
    "globals": "17.7.0",
    "turbo": "^2",
    "typescript-eslint": "8.65.0"
  }
}
