{
  "name": "blau-web",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/check-build-size.mjs && node scripts/check-security-headers.mjs",
    "check": "astro check",
    "check:size": "node scripts/check-build-size.mjs",
    "lint": "eslint .",
    "preview": "astro preview",
    "test": "node --test test/*.test.mjs",
    "deploy": "wrangler deploy",
    "deploy:list": "wrangler deployments list",
    "rollback": "wrangler rollback"
  },
  "dependencies": {
    "astro": "6.4.8"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "typescript": "6.0.3",
    "wrangler": "4.110.0"
  }
}
