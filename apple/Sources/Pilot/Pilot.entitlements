<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Pilot embeds a Ghostty terminal and launches arbitrary shells/IDEs via
	     /usr/bin/login, which the App Sandbox forbids (it can't exec the
	     setuid login binary outside the container). A terminal emulator can't
	     run sandboxed, so the app ships unsandboxed — which also grants full
	     network access (Bonjour/multicast for the Plotter mirror) without the
	     sandbox-scoped network/device entitlements. -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
</dict>
</plist>
