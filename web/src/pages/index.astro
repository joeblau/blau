---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import pilotImg from '../assets/screenshots/pilot.png';
import copilotImg from '../assets/screenshots/copilot.png';
import wingmanImg from '../assets/screenshots/wingman.png';
---

<Layout
  title="blau — a native Apple developer cockpit"
  description="blau is a four-app native Apple ecosystem: Pilot (macOS) is a dev command-center with embedded Ghostty terminals, a WebKit browser, and git tooling — synced peer-to-peer to iPhone, Apple Watch, and a live HEVC screen mirror on iPad. No servers. No accounts."
>
  <span id="top" aria-hidden="true"></span>

  <nav id="nav" class="nav glass" data-nav aria-label="Primary">
    <div class="container container--wide nav__inner">
      <div class="nav__lead">
        <a class="nav__wordmark" href="#top" aria-label="blau — home">blau</a>
        <span class="nav__status mono" aria-hidden="false">open source</span>
      </div>

      <ul class="nav__links" role="list">
        <li><a class="nav__link is-active" href="#cockpit" aria-current="true">Cockpit</a></li>
        <li><a class="nav__link" href="#platforms">Apps</a></li>
        <li><a class="nav__link" href="#architecture">Architecture</a></li>
        <li><a class="nav__link" href="#built-on">Built on</a></li>
      </ul>

      <a class="btn btn-ghost nav__cta" href="https://github.com/joeblau/blau" target="_blank" rel="noopener noreferrer">
        <svg class="nav__gh" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
          <path fill="currentColor" fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z" clip-rule="evenodd"/>
        </svg>
        GitHub
        <span class="nav__arrow" aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </nav>

  <section id="hero" class="hero">
    <div class="hero__glow" aria-hidden="true"></div>

    <div class="container hero__inner">
      <p class="eyebrow eyebrow--accent hero__eyebrow" data-reveal>Native Apple Dev Cockpit</p>

      <h1 class="h1 gradient-text hero__title" data-reveal style="--delay:60ms">
        Your terminal, browser, and devices&nbsp;&mdash;<br class="hero__br" />
        one cockpit, four screens.
      </h1>

      <p class="lead hero__lead" data-reveal style="--delay:120ms">
        blau is a four-app native Apple ecosystem built around Pilot, a macOS command-center with real Ghostty terminals, a WebKit browser, and git tooling. Your iPhone drives the cursor, your Watch presses Enter, and your iPad mirrors the screen over the air &mdash; no servers, no accounts, no cloud in the path.
      </p>

      <div class="hero__cta" data-reveal style="--delay:180ms">
        <a class="btn btn-primary btn--lg" href="https://github.com/joeblau/blau" target="_blank" rel="noopener">
          <svg class="hero__gh" width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          Get it on GitHub
        </a>
        <a class="btn btn-ghost btn--lg" href="#architecture">
          See the architecture
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h9M8.5 4.5L12 8l-3.5 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <dl class="hero__stats mono" data-reveal style="--delay:240ms">
        <div class="hero__stat">
          <dt class="hero__stat-num">4 apps</dt>
          <dd class="hero__stat-desc">macOS / iOS / watchOS / iPadOS</dd>
        </div>
        <span class="hero__stat-rule" aria-hidden="true"></span>
        <div class="hero__stat">
          <dt class="hero__stat-num">2 transports</dt>
          <dd class="hero__stat-desc">control + media, both peer-to-peer</dd>
        </div>
        <span class="hero__stat-rule" aria-hidden="true"></span>
        <div class="hero__stat">
          <dt class="hero__stat-num">0 servers</dt>
          <dd class="hero__stat-desc">discovery and data stay on your network</dd>
        </div>
      </dl>

      <figure class="hero__showcase" data-reveal style="--delay:320ms">
        <figcaption class="hero__caption mono">pilot.app &mdash; terminal &middot; browser &middot; device mirror &middot; git inspector</figcaption>
        <div class="pane hero__pane">
          <div class="pane__bar">
            <span class="pane__dot"></span>
            <span class="pane__dot"></span>
            <span class="pane__dot"></span>
            <span class="pane__title">Pilot &mdash; macOS</span>
          </div>
          <div class="hero__shot">
            <Image src={pilotImg} alt="Pilot for macOS: a command-center showing live Ghostty terminals, a WebKit browser pane, and a git inspector side by side." loading="eager" decoding="async" />
          </div>
        </div>
      </figure>
    </div>
  </section>

  <section id="platforms" class="apps section">
    <div class="container container--wide">
      <header class="apps__head">
        <span class="eyebrow eyebrow--accent" data-reveal>The ecosystem</span>
        <h2 class="h2 apps__title" data-reveal style="--delay:60ms">Four apps. One Mac does the work.</h2>
        <p class="lead apps__intro" data-reveal style="--delay:120ms">Pilot runs everything on the desktop. The other three are honest peripherals &mdash; each does one job, natively, on its own device.</p>
      </header>

      <div class="apps__grid">

        <!-- Pilot — hero cell -->
        <article class="card card--hover apps__card apps__card--pilot" data-reveal style="--delay:0ms">
          <div class="apps__cardhead">
            <h3 class="h3 apps__name">Pilot</h3>
            <span class="chip apps__chip apps__chip--accent"><span class="chip__led chip__led--accent"></span>macOS &middot; the cockpit</span>
          </div>
          <p class="apps__body muted">The command-center. Split panes of real Ghostty terminals, a WebKit browser, a USB-tethered iPhone mirror, and a git / GitHub inspector &mdash; with notes and freehand annotation on top.</p>

          <div class="apps__pilotshot" aria-hidden="true">
            <div class="pane apps__pane">
              <div class="pane__bar">
                <span class="pane__dot"></span><span class="pane__dot"></span><span class="pane__dot"></span>
                <span class="pane__title">pilot — ~/dev</span>
              </div>
              <div class="apps__paneimg">
                <Image src={pilotImg} alt="Pilot on macOS: split terminal, browser, and device-mirror panes." loading="lazy" decoding="async" />
              </div>
            </div>
          </div>
        </article>

        <!-- Copilot -->
        <article class="card card--hover apps__card apps__card--copilot" data-reveal style="--delay:60ms">
          <div class="apps__cardhead">
            <h3 class="h3 apps__name">Copilot</h3>
            <span class="chip apps__chip"><span class="chip__led"></span>iOS</span>
          </div>
          <p class="apps__body muted">Mirrors Pilot's workspace list, drives the Mac cursor from a touch trackpad, switches panes, and transcribes your voice on-device to paste into the active terminal.</p>
          <div class="apps__phone" aria-hidden="true">
            <Image src={copilotImg} alt="Copilot on iPhone: workspace list and touch trackpad." loading="lazy" decoding="async" />
          </div>
        </article>

        <!-- Wingman -->
        <article class="card card--hover apps__card apps__card--wingman" data-reveal style="--delay:120ms">
          <div class="apps__cardhead">
            <h3 class="h3 apps__name">Wingman</h3>
            <span class="chip apps__chip"><span class="chip__led"></span>watchOS</span>
          </div>
          <p class="apps__body muted">A double-pinch on your wrist becomes an Enter keypress on the Mac. One gesture, one job, with haptic confirmation.</p>
          <div class="apps__watch" aria-hidden="true">
            <Image src={wingmanImg} alt="Wingman on Apple Watch." loading="lazy" decoding="async" />
          </div>
        </article>

        <!-- Plotter -->
        <article class="card card--hover apps__card apps__card--plotter" data-reveal style="--delay:180ms">
          <div class="apps__cardhead">
            <h3 class="h3 apps__name">Plotter</h3>
            <span class="chip apps__chip"><span class="chip__led"></span>iPadOS</span>
          </div>
          <p class="apps__body muted">Receives Pilot's screen as a live HEVC stream and lets you mark it up with Apple Pencil &mdash; strokes round-trip back onto the Mac. Includes a widget and Live Activity.</p>
          <div class="apps__ipad" aria-hidden="true">
            <div class="apps__bezel">
              <img src="/screenshots/plotter/01-mirror.png" alt="Plotter on iPad: live mirror of the Mac screen with Apple Pencil markup." loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

      </div>

      <p class="apps__footnote mono" data-reveal style="--delay:240ms">+ blau.app &mdash; this site, built with Astro</p>
    </div>
  </section>

  <section id="cockpit" class="cockpit section">
    <div class="container container--wide">

      <header class="cockpit__head">
        <span class="eyebrow eyebrow--accent reveal" data-reveal>Inside Pilot</span>
        <h2 class="h2 cockpit__title reveal" data-reveal style="--delay:60ms">
          Six real panes, rendered by the platform.
        </h2>
        <p class="lead measure cockpit__lead reveal" data-reveal style="--delay:120ms">
          No Electron, no web-view IDE. The terminal is libghostty rendered through Metal;
          the browser is WKWebView; everything else is SwiftUI and AppKit.
        </p>
      </header>

      <figure class="cockpit__shot reveal" data-reveal style="--delay:160ms">
        <div class="pane cockpit__pane">
          <div class="pane__bar">
            <span class="pane__dot"></span>
            <span class="pane__dot"></span>
            <span class="pane__dot"></span>
            <span class="pane__title">pilot — workspace · ~/dev/blau</span>
          </div>
          <Image src={pilotImg} alt="Pilot for macOS showing terminal, browser, device mirror and git panes side by side" loading="lazy" decoding="async" />
        </div>
        <figcaption class="cockpit__cap mono">
          <span class="cockpit__cap-led" aria-hidden="true"></span>
          pilot.app — six native panes in one resizable window
        </figcaption>
      </figure>

      <ol class="cockpit__list" role="list">

        <li class="cockpit__row reveal" data-reveal style="--delay:50ms">
          <span class="cockpit__idx mono" aria-hidden="true">01 / TERMINAL</span>
          <div class="cockpit__body">
            <h3 class="cockpit__h">Ghostty terminal panes</h3>
            <p class="cockpit__p">
              Real libghostty — the same GPU-accelerated, Metal-rendered engine as the
              standalone Ghostty app — in resizable, collapsible splits. Per-pane working
              directory tracked over OSC 7; sessions persist across relaunch.
            </p>
          </div>
        </li>

        <li class="cockpit__row reveal" data-reveal style="--delay:100ms">
          <span class="cockpit__idx mono" aria-hidden="true">02 / BROWSER</span>
          <div class="cockpit__body">
            <h3 class="cockpit__h">WebKit browser pane</h3>
            <p class="cockpit__p">
              A full WKWebView with address bar, back / forward / reload, Web Inspector,
              and downloads. It scans your repo for package.json and framework configs to
              offer one-click dev-server links — Next 3000, Vite 5173, Astro 4321.
            </p>
          </div>
        </li>

        <li class="cockpit__row reveal" data-reveal style="--delay:150ms">
          <span class="cockpit__idx mono" aria-hidden="true">03 / DEVICE</span>
          <div class="cockpit__body">
            <h3 class="cockpit__h">USB iPhone mirror</h3>
            <p class="cockpit__p">
              Mirrors a tethered iPhone via AVFoundation and CoreMediaIO, QuickTime-style.
              Record to a .mov on your Desktop or grab a screenshot to clipboard, without
              leaving the window.
            </p>
          </div>
        </li>

        <li class="cockpit__row reveal" data-reveal style="--delay:200ms">
          <span class="cockpit__idx mono" aria-hidden="true">04 / GIT</span>
          <div class="cockpit__body">
            <h3 class="cockpit__h">Git &amp; GitHub inspector</h3>
            <p class="cockpit__p">
              Recent commits from git log, Actions runs and open issues from the gh CLI.
              Click an issue and Pilot pastes an agent-ready ‘implement #N’ prompt into the
              active terminal — and badges any workspace when its background Action finishes.
            </p>
          </div>
        </li>

        <li class="cockpit__row reveal" data-reveal style="--delay:250ms">
          <span class="cockpit__idx mono" aria-hidden="true">05 / NOTES</span>
          <div class="cockpit__body">
            <h3 class="cockpit__h">Markdown notes</h3>
            <p class="cockpit__p">
              A live GitHub-Flavored-Markdown editor with split-into-lines multi-cursor,
              clickable task checkboxes, code-block copy, and .env secrets masked until you
              click to reveal.
            </p>
          </div>
        </li>

        <li class="cockpit__row reveal" data-reveal style="--delay:300ms">
          <span class="cockpit__idx mono" aria-hidden="true">06 / ANNOTATION</span>
          <div class="cockpit__body">
            <h3 class="cockpit__h">Freehand ink overlay</h3>
            <p class="cockpit__p">
              Draw straight over the active pane with a native AppKit canvas — color
              palette, eraser, undo, clear. SwiftData keeps your workspaces, panes, browser
              state, and notes across launches.
            </p>
          </div>
        </li>

      </ol>

    </div>
  </section>

  <section id="mirror" class="mirror section">
    <div class="container container--wide mirror__grid">

      <div class="mirror__col mirror__text">
        <span class="eyebrow eyebrow--accent" data-reveal>LIVE MIRROR · PILOT → PLOTTER</span>
        <h2 class="h2 mirror__head" data-reveal style="--delay:60ms">Your Mac screen, on the iPad, in real time.</h2>
        <p class="mirror__body measure muted" data-reveal style="--delay:120ms">
          Pilot captures its own window with ScreenCaptureKit, encodes HEVC on Apple's dedicated media engine with VideoToolbox, and streams it to Plotter over a direct device-to-device Wi-Fi link. Plotter hardware-decodes it, and your Apple Pencil strokes are normalized to the video frame and sent back — Pilot renders them over its own window. Undo and clear sync both ways.
        </p>

        <ol class="mirror__pipe" data-reveal style="--delay:180ms">
          <li class="mirror__step" data-reveal style="--delay:200ms">
            <span class="mirror__node" aria-hidden="true"></span>
            <span class="mirror__num mono">01</span>
            <span class="mirror__label mono">Capture</span>
            <p class="mirror__desc">ScreenCaptureKit grabs Pilot's window as IOSurface-backed frames, up to 4K / 60fps, skipping idle frames.</p>
          </li>
          <li class="mirror__step" data-reveal style="--delay:270ms">
            <span class="mirror__node" aria-hidden="true"></span>
            <span class="mirror__num mono">02</span>
            <span class="mirror__label mono">Encode</span>
            <p class="mirror__desc">VideoToolbox compresses to HEVC on the media engine — same picture in roughly half the bits of H.264.</p>
          </li>
          <li class="mirror__step" data-reveal style="--delay:340ms">
            <span class="mirror__node" aria-hidden="true"></span>
            <span class="mirror__num mono">03</span>
            <span class="mirror__label mono">Stream</span>
            <p class="mirror__desc">FrameLink sends length-prefixed packets over Network.framework on the local link; capture only runs while a Plotter is connected.</p>
          </li>
          <li class="mirror__step" data-reveal style="--delay:410ms">
            <span class="mirror__node" aria-hidden="true"></span>
            <span class="mirror__num mono">04</span>
            <span class="mirror__label mono">Annotate</span>
            <p class="mirror__desc">PencilKit strokes on the iPad round-trip to the Mac; Plotter reports link quality so Pilot adapts its bitrate.</p>
          </li>
        </ol>

        <p class="mirror__quote mono faint" data-reveal style="--delay:480ms">
          Hardware all the way down — capture, encode, and decode never touch your CPU.
        </p>
      </div>

      <div class="mirror__col mirror__media" data-reveal style="--delay:120ms">
        <figure class="mirror__frame">
          <img src="/screenshots/plotter/01-mirror.png" alt="Pilot's macOS window mirrored live onto an iPad with Apple Pencil annotation" class="mirror__img" loading="lazy" decoding="async" width="1600" height="1200" />
          <figcaption class="chip mirror__chip">
            <span class="chip__led" aria-hidden="true"></span>
            HEVC · 60fps · link-up
          </figcaption>
        </figure>
      </div>

    </div>
  </section>

  <section id="voice" class="voice section">
    <div class="container voice__grid">

      <!-- LEFT: device frame with screenshot -->
      <div class="voice__media" data-reveal>
        <div class="voice__phone">
          <div class="voice__notch" aria-hidden="true"></div>
          <img
            class="voice__shot"
            src="/screenshots/copilot/01-workspaces.png"
            alt="Copilot workspaces list on iPhone with an on-screen trackpad"
            loading="lazy"
            decoding="async"
            width="603"
            height="1305"
          />
        </div>
        <span class="chip voice__chip">
          <span class="chip__led chip__led--accent" aria-hidden="true"></span>
          on-device · 0 bytes audio sent
        </span>
      </div>

      <!-- RIGHT: copy + control cards -->
      <div class="voice__body">
        <div class="voice__intro" data-reveal>
          <span class="eyebrow eyebrow--accent">Voice &amp; Control</span>
          <h2 class="h2 voice__title">Talk to your terminal. Nothing leaves the device.</h2>
          <p class="lead voice__lead">
            Hold Copilot's volume-down button to record; WhisperKit transcribes your speech locally on the iPhone with Apple's Core ML — no audio ever crosses the wire. Only the finished text is sent, and Pilot pastes it into the active terminal. Hold volume-up to send Enter.
          </p>
        </div>

        <div class="voice__cards">
          <article class="card card--hover voice__card" data-reveal style="--delay:0ms">
            <span class="mono voice__kicker">PUSH-TO-TALK</span>
            <h3 class="voice__cardTitle">On-device transcription</h3>
            <p class="voice__cardText">WhisperKit (openai_whisper-base) runs Whisper on Apple Silicon via Core ML. Audio is transcribed on the phone; just the text is delivered.</p>
          </article>

          <article class="card card--hover voice__card" data-reveal style="--delay:50ms">
            <span class="mono voice__kicker">TRACKPAD</span>
            <h3 class="voice__cardTitle">Cursor from your pocket</h3>
            <p class="voice__cardText">Copilot's touch trackpad sends relative mouse deltas and clicks; Pilot posts real CGEvents through the Accessibility API.</p>
          </article>

          <article class="card card--hover voice__card" data-reveal style="--delay:100ms">
            <span class="mono voice__kicker">VOLUME NAV</span>
            <h3 class="voice__cardTitle">Hardware-button workspaces</h3>
            <p class="voice__cardText">A KVO state machine on outputVolume turns the volume buttons into list navigation — the system volume HUD is suppressed by a hidden MPVolumeView.</p>
          </article>

          <article class="card card--hover voice__card" data-reveal style="--delay:150ms">
            <span class="mono voice__kicker">WATCH</span>
            <h3 class="voice__cardTitle">Double-pinch = Enter</h3>
            <p class="voice__cardText">Wingman sends a double-pinch over WatchConnectivity to Copilot, which relays it to Pilot as an Enter keypress, with haptic confirmation.</p>
          </article>
        </div>

        <div class="voice__quote mono" data-reveal style="--delay:200ms">
          <span class="voice__prompt" aria-hidden="true">›</span>
          <code><span class="voice__kw">import</span> WhisperKit — on-device, MIT-licensed, auditable. No cloud STT.</code>
        </div>
      </div>

    </div>
  </section>

  <section id="architecture" class="arch">
    <div class="container">
      <header class="arch__head">
        <span class="eyebrow eyebrow--accent reveal">ARCHITECTURE</span>
        <h2 class="h2 arch__title reveal" style="--delay: 0.05s">Two transports. Zero servers.</h2>
        <p class="lead arch__lead reveal" style="--delay: 0.1s">
          Devices find each other over Bonjour and talk directly. Control sync — workspace state, selection, trackpad, voice text, device status — runs over MultipeerConnectivity with an encrypted MCSession. The high-bandwidth screen mirror and annotation channels run over Apple's Network.framework as length-prefixed packets on the local link. Discovery and data never leave your network. There is no backend to breach, no telemetry hop, no account to create.
        </p>
      </header>

      <div class="arch__panel card reveal" style="--delay: 0.15s">
        <div class="arch__panel-bar">
          <span class="arch__panel-label mono">topology · live</span>
          <ul class="arch__legend">
            <li class="arch__legend-item mono">
              <span class="arch__legend-swatch arch__legend-swatch--control" aria-hidden="true"></span>
              control · MultipeerConnectivity
            </li>
            <li class="arch__legend-item mono">
              <span class="arch__legend-swatch arch__legend-swatch--media" aria-hidden="true"></span>
              media · Network.framework
            </li>
          </ul>
        </div>

        <!-- DESKTOP / WIDE: hand-built topology diagram -->
        <div class="arch__diagram" role="img" aria-label="Topology: Mac running Pilot at center, connected to iPhone (Copilot) and iPad (Plotter) over two transports, with Apple Watch (Wingman) tethered off the iPhone.">
          <svg class="arch__wires" viewBox="0 0 1000 560" preserveAspectRatio="none" aria-hidden="true" focusable="false">
            <defs>
              <linearGradient id="archMediaGrad" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0" stop-color="var(--accent)" stop-opacity="0.05"/>
                <stop offset="0.5" stop-color="var(--accent)" stop-opacity="0.55"/>
                <stop offset="1" stop-color="var(--accent)" stop-opacity="0.05"/>
              </linearGradient>
            </defs>

            <!-- control: Pilot <-> Copilot (left) -->
            <path class="arch__edge arch__edge--control" d="M 360 240 L 175 240" pathLength="100"/>
            <!-- control: Copilot <-> Wingman (lower-left, tether) -->
            <path class="arch__edge arch__edge--control" d="M 130 300 L 130 430" pathLength="100"/>
            <!-- media: Pilot -> Plotter (upper-right) -->
            <path class="arch__edge arch__edge--media" d="M 640 215 L 845 150" pathLength="100"/>
            <!-- media: Plotter -> Pilot (lower-right) -->
            <path class="arch__edge arch__edge--media" d="M 845 230 L 640 285" pathLength="100"/>

            <!-- traveling dots on media edges -->
            <circle class="arch__pkt arch__pkt--out" r="3.5" aria-hidden="true">
              <animateMotion dur="4.5s" repeatCount="indefinite" path="M 640 215 L 845 150" keyPoints="0;1" keyTimes="0;1" calcMode="linear"/>
            </circle>
            <circle class="arch__pkt arch__pkt--in" r="3.5" aria-hidden="true">
