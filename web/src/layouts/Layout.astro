---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'blau is a four-app native Apple ecosystem: Pilot (macOS) is a dev command-center with embedded Ghostty terminals, a WebKit browser, and git tooling — synced peer-to-peer to iPhone, Apple Watch, and a live HEVC screen mirror on iPad. No servers. No accounts.',
} = Astro.props;

const ogImage = new URL('/og.png', Astro.site ?? 'https://blau.app').href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#08080A" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://blau.app" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="blau — a native Apple developer cockpit" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://rsms.me" crossorigin />

    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script src="../scripts/animations.ts"></script>
  </body>
</html>

<style is:global>
  @import '../styles/tokens.css';
  @import '../styles/global.css';
  @import '../styles/sections.css';
  @import '../styles/animations.css';
</style>
